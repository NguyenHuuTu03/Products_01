extends ../../layouts/default.pug
include ../..//mixins/filter-status.pug
include ../..//mixins/search.pug
include ../..//mixins/pagination.pug
include ../..//mixins/form-change-multi.pug
include ../..//mixins/alert.pug

block main
  .container-fluid.mt-3
    +alertSuccess(5000)
    .row
      .col-12
        h2 Danh sách sản phẩm

    

    //- // Bộ lọc tìm kiếm
    //- .row.mt-3
    //-   .col-12
    //-     form(method="GET", action= prefixAdmin + "/products")
    //-       .row
    //-         .col-md-4
    //-           input.form-control(
    //-             type="text",
    //-             name="keyword",
    //-             placeholder="Tìm tên sản phẩm..."
    //-           )
    //-         .col-md-3
    //-           select.form-select(name="status")
    //-             option(value="") -- Trạng thái --
    //-             option(value="active") Hoạt động
    //-             option(value="inactive") Dừng hoạt động
    //-         .col-md-2
    //-           button.btn.btn-success(type="submit") Tìm kiếm
    .card.mb-3
      .card-header Bộ lọc và Tìm kiếm
      .card-body
        .row 
          .col-6
            // Bộ lọc trạng thái
            .filter-status
              +filterStatus(filtersStatus)

          // Thanh tìm kiếm
          .col-6
            +search(keyword)
      
    .card.mb-3
      .card-header Danh sách sản phẩm
      .card-body
        .row 
          .col-8 
            +form-change-multi(`${prefixAdmin}/products/change-multi?_method=PATCH`)
          .col-4 
            a.btn.btn-primary(href= prefixAdmin + "/products/create") + Thêm sản phẩm
        table(class="table table-bordered table-hover table-sm" checkbox-multi)
          thead
            tr
              th  
                input(type="checkbox", name="checkall")
              th ID
              th Ảnh
              th Tên sản phẩm
              th Giá
              th Vị trí
              th Trạng thái
              th Hành động
          tbody
            each item, index in products
              tr
                td 
                  input(type="checkbox", name="id", value=item.id)
                td #{index + 1}
                td
                  img(src=item.thumbnail, alt=item.title)
                td #{item.title}
                td #{item.price} $
                td 
                  input(type="number", name="position", value=item.position, style="width: 60px", min="1")
                td
                  if item.status == "active"
                    //- href = "javascript:" có nghĩa là dùng javascript để xử lý logic
                    a(href="javascript:;" class="badge bg-success"
                      button-change-status
                      data-status=item.status
                      data-id=item.id
                    ) Hoạt động
                  else
                    a(href="javascript:;" class="badge bg-danger"
                      button-change-status
                      data-status=item.status
                      data-id=item.id
                    ) Dừng hoạt động
                                                          
                td
                  a(class="btn btn-secondary btn-sm" button-detail data-id=item.id href=`${prefixAdmin}/products/detail/${item.id}`) Chi tiết
                  a(class="btn btn-warning btn-sm" button-edit data-id=item.id href=`${prefixAdmin}/products/edit/${item.id}`) Sửa
                  button(class="btn btn-danger btn-sm" button-delete data-id=item.id) Xóa
    +pagination(pagination)

    form(action="", method="POST", id="form-change-status", data-path=`${prefixAdmin}/products/change-status`)  
    form(action="", method="POST", id="form-delete-item", data-path=`${prefixAdmin}/products/delete`)  
    script(src="/admin/js/product.js")