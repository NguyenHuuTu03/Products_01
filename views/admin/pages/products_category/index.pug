extends ../../layouts/default.pug
include ../../mixins/table-tree.pug
block main
  .container-fluid.mt-3
    .row
      .col-12
        h2 Danh sách sản phẩm

    .card.mb-3
      .card-header Danh mục sản phẩm

      .card-body
        // ===== BUTTON =====
        .row.mb-3
          .col-4
            a.btn.btn-primary(
              href= prefixAdmin + "/products-category/create"
            ) + Thêm danh mục

        // ===== TABLE =====
        .table-responsive
          table.table.table-bordered.table-hover.table-sm(checkbox-multi)
            thead
              tr
                th
                  input(type="checkbox", name="checkall")
                th ID
                th Ảnh
                th Tên danh mục
                th Vị trí
                th Trạng thái
                th Hành động

            tbody
              +table-tree(records)

  script(src="/admin/js/product.js")