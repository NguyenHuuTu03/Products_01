extends ../../layouts/default.pug

block main
  .container.mt-4

    .card.border-0.shadow-sm.rounded-4.p-4
      .row.g-4.align-items-center

        // ===== ẢNH =====
        .col-md-5
          .product-image
            img(
              src=product.thumbnail || "/images/no-image.png"
              alt=product.title
            )

        // ===== THÔNG TIN =====
        .col-md-7

          h2.product-title.mb-3= product.title

          // ===== GIÁ =====
          if product.discountPercentage > 0
            .price-box.mb-3
              span.old-price #{product.price.toLocaleString()} đ
              span.new-price
                | #{(product.price * (100 - product.discountPercentage) / 100).toLocaleString()} đ
              span.discount -#{product.discountPercentage}%
          else
            .price-box.mb-3
              span.new-price #{product.price.toLocaleString()} đ

          // ===== TRẠNG THÁI + STOCK =====
          .d-flex.align-items-center.gap-3.mb-3
            if product.status == "active"
              span.badge.bg-success.px-3.py-2 Còn hàng
            else
              span.badge.bg-danger.px-3.py-2 Hết hàng

            span.text-muted
              | Kho: 
              strong #{product.stock}

          hr

          // ===== MUA HÀNG =====
          form(action=`/cart/add/${product._id}` method="POST")
            .d-flex.align-items-center.gap-2

              input.form-control.quantity-input(
                type="number"
                name="quantity"
                value="1"
                min="1"
              )

              button.btn.btn-danger.btn-lg.flex-grow-1
                i(class="fa fa-shopping-cart me-2")
                | Thêm vào giỏ hàng

    // ===== MÔ TẢ =====
    .card.border-0.shadow-sm.rounded-4.mt-4.p-4
      h4.mb-3 Mô tả sản phẩm

      if product.description
        .product-desc #{product.description}
      else
        p.text-muted Không có mô tả